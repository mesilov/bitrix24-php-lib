{% extends '@Journal/layout.html.twig' %}

{% block title %}Список записей журнала - Технологический журнал{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="{{ path('journal_admin_list') }}">Журнал</a></li>
            <li class="breadcrumb-item active" aria-current="page">Список записей</li>
        </ol>
    </nav>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .level-emergency, .level-alert, .level-critical { background-color: #dc3545 !important; }
        .level-error { background-color: #fd7e14 !important; }
        .level-warning { background-color: #ffc107 !important; color: #000 !important; }
        .level-notice { background-color: #0dcaf0 !important; }
        .level-info { background-color: #198754 !important; }
        .level-debug { background-color: #6c757d !important; }
    </style>
{% endblock %}

{% block body %}
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
            <h5 class="mb-0">Фильтры</h5>
        </div>
        <div class="card-body bg-light">
            <form method="get" action="{{ path('journal_admin_list') }}">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label for="domain" class="form-label fw-semibold">Домен портала</label>
                        <select name="domain" id="domain" class="form-select">
                            <option value="">Все домены</option>
                            {% for domain in availableDomains %}
                                <option value="{{ domain }}" {% if currentFilters.domain == domain %}selected{% endif %}>
                                    {{ domain }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label for="level" class="form-label fw-semibold">Уровень</label>
                        <select name="level" id="level" class="form-select">
                            <option value="">Все уровни</option>
                            {% for logLevel in logLevels %}
                                <option value="{{ logLevel.value }}" {% if currentFilters.level == logLevel.value %}selected{% endif %}>
                                    {{ logLevel.value|upper }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label for="label" class="form-label fw-semibold">Метка</label>
                        <select name="label" id="label" class="form-select">
                            <option value="">Все метки</option>
                            {% for availableLabel in availableLabels %}
                                <option value="{{ availableLabel }}" {% if currentFilters.label == availableLabel %}selected{% endif %}>
                                    {{ availableLabel }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-funnel"></i> Применить фильтры
                    </button>
                    <a href="{{ path('journal_admin_list') }}" class="btn btn-secondary">
                        <i class="bi bi-x-circle"></i> Сбросить
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Записи журнала</h5>
            <span class="badge bg-secondary">
                Всего: {{ pagination.getTotalItemCount }} | Страница {{ pagination.getCurrentPageNumber }} из {{ pagination.getPageCount }}
            </span>
        </div>
        <div class="card-body p-0">
            {% if pagination.getTotalItemCount > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Дата и время</th>
                                <th>Уровень</th>
                                <th>Сообщение</th>
                                <th>Метка</th>
                                <th>User ID</th>
                                <th>IP</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in pagination %}
                                <tr>
                                    <td class="text-nowrap">
                                        <small>{{ item.createdAt.format('Y-m-d H:i:s') }}</small>
                                    </td>
                                    <td>
                                        <span class="badge level-{{ item.level.value }}">
                                            {{ item.level.value }}
                                        </span>
                                    </td>
                                    <td>{{ item.message|length > 100 ? item.message|slice(0, 100) ~ '...' : item.message }}</td>
                                    <td>
                                        {% if item.context.label %}
                                            <span class="badge bg-light text-dark border">{{ item.context.label }}</span>
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ item.context.bitrix24UserId ?? '—' }}</td>
                                    <td><small>{{ item.context.ipAddress ? item.context.ipAddress.compactedAddress : '—' }}</small></td>
                                    <td>
                                        <a href="{{ path('journal_admin_show', {id: item.id}) }}" class="btn btn-sm btn-outline-primary">
                                            Просмотр
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                {% if pagination.getPageCount > 1 %}
                    <nav aria-label="Навигация по страницам" class="mt-3 px-3 pb-3">
                        <ul class="pagination justify-content-center mb-0">
                            {% if pagination.getCurrentPageNumber > 1 %}
                                <li class="page-item">
                                    <a class="page-link" href="{{ path('journal_admin_list', currentFilters|merge({page: 1})) }}">
                                        « Первая
                                    </a>
                                </li>
                                <li class="page-item">
                                    <a class="page-link" href="{{ path('journal_admin_list', currentFilters|merge({page: pagination.getCurrentPageNumber - 1})) }}">
                                        ‹ Предыдущая
                                    </a>
                                </li>
                            {% endif %}

                            {% for page in 1..pagination.getPageCount %}
                                {% if page == pagination.getCurrentPageNumber %}
                                    <li class="page-item active">
                                        <span class="page-link">{{ page }}</span>
                                    </li>
                                {% elseif page >= pagination.getCurrentPageNumber - 2 and page <= pagination.getCurrentPageNumber + 2 %}
                                    <li class="page-item">
                                        <a class="page-link" href="{{ path('journal_admin_list', currentFilters|merge({page: page})) }}">
                                            {{ page }}
                                        </a>
                                    </li>
                                {% endif %}
                            {% endfor %}

                            {% if pagination.getCurrentPageNumber < pagination.getPageCount %}
                                <li class="page-item">
                                    <a class="page-link" href="{{ path('journal_admin_list', currentFilters|merge({page: pagination.getCurrentPageNumber + 1})) }}">
                                        Следующая ›
                                    </a>
                                </li>
                                <li class="page-item">
                                    <a class="page-link" href="{{ path('journal_admin_list', currentFilters|merge({page: pagination.getPageCount})) }}">
                                        Последняя »
                                    </a>
                                </li>
                            {% endif %}
                        </ul>
                    </nav>
                {% endif %}
            {% else %}
                <div class="alert alert-info m-3 text-center">
                    <i class="bi bi-info-circle"></i> Записи не найдены. Попробуйте изменить параметры фильтрации.
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
