<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Технологический журнал{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-light">
    <header class="bg-white border-bottom shadow-sm mb-4">
        <div class="container py-3">
            <h1 class="h3 mb-2">{% block header_title %}Технологический журнал{% endblock %}</h1>
            {% block breadcrumb %}{% endblock %}
        </div>
    </header>

    <main class="container pb-5">
        {% block body %}{% endblock %}
    </main>

    <footer class="bg-white border-top mt-auto py-3">
        <div class="container text-center text-muted">
            <small>&copy; {{ "now"|date("Y") }} Bitrix24 PHP Library - Технологический журнал</small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>
