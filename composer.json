{
  "name": "mesilov/bitrix24-php-lib",
  "description": "A powerful PHP library for rapid Bitrix24 application development",
  "keywords": [
    "Bitrix24",
    "PHP",
    "REST",
    "API",
    "Bitrix24 Application",
    "SaaS"
  ],
  "type": "library",
  "homepage": "https://github.com/mesilov/bitrix24-php-lib",
  "license": "MIT",
  "authors": [
    {
      "name": "Maksim Mesilov",
      "homepage": "https://github.com/mesilov/"
    }
  ],
  "support": {
    "issues": "https://github.com/mesilov/bitrix24-php-lib/issues?state=open",
    "source": "https://github.com/mesilov/bitrix24-php-lib"
  },
  "minimum-stability": "stable",
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "preferred-install": {
      "*": "dist",
      "bitrix24/b24phpsdk": "source"
    }
  },
  "require": {
    "php": "8.4.* || 8.5.*",
    "ext-bcmath": "*",
    "ext-curl": "*",
    "ext-dom": "*",
    "ext-intl": "*",
    "ext-json": "*",
    "bitrix24/b24phpsdk": "dev-v3-dev",
    "darsyn/ip": "^5",
    "doctrine/doctrine-bundle": "*",
    "doctrine/doctrine-migrations-bundle": "*",
    "doctrine/orm": "^3",
    "fig/http-message-util": "^1",
    "giggsey/libphonenumber-for-php": "^8",
    "knplabs/knp-paginator-bundle": "^6",
    "league/csv": "^9.0",
    "moneyphp/money": "^4",
    "nesbot/carbon": "^3",
    "nyholm/psr7": "^1.8",
    "odolbeau/phone-number-bundle": "^3.0",
    "php-http/discovery": "^1.20",
    "php-http/message": "^1.16",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.1",
    "psr/log": "^3",
    "symfony/cache": "^7",
    "symfony/console": "^7",
    "symfony/css-selector": "^8.0",
    "symfony/dom-crawler": "^8.0",
    "symfony/dotenv": "^7",
    "symfony/event-dispatcher": "^7",
    "symfony/http-client": "^7",
    "symfony/serializer": "^7",
    "symfony/uid": "^7",
    "symfony/yaml": "^7"
  },
  "require-dev": {
    "lendable/composer-license-checker": "^1.2",
    "friendsofphp/php-cs-fixer": "^3.64",
    "monolog/monolog": "^3",
    "fakerphp/faker": "^1",
    "phpstan/phpstan": "^1",
    "phpunit/phpunit": "^12",
    "doctrine/migrations": "^3",
    "psalm/phar": "^5",
    "rector/rector": "^1",
    "roave/security-advisories": "dev-master",
    "symfony/debug-bundle": "^7",
    "symfony/stopwatch": "^7",
    "symfony/var-exporter": "^7",
    "symfony/http-kernel": "^7"
  },
  "suggest": {
    "php-http/guzzle7-adapter": "For Guzzle HTTP client",
    "symfony/http-client": "For Symfony HTTP client",
    "php-http/curl-client": "For cURL-based client"
  },
  "autoload": {
    "psr-4": {
      "Bitrix24\\Lib\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Bitrix24\\Lib\\Tests\\": "tests",
      "Bitrix24\\SDK\\Tests\\": "vendor/bitrix24/b24phpsdk/tests"
    }
  }
}
