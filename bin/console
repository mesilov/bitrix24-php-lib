#!/usr/bin/env php
<?php

require __DIR__ . '/../vendor/autoload.php';

(new Symfony\Component\Dotenv\Dotenv())->load(__DIR__ . '/../.env.local');

use Bitrix24\Lib\Bitrix24Partners\Infrastructure\Doctrine\Bitrix24PartnerRepository;
use Bitrix24\Lib\Services\Flusher;
use Bitrix24\Lib\Tests\EntityManagerFactory;
use libphonenumber\PhoneNumberUtil;
use Psr\Log\NullLogger;
use Symfony\Component\Console\Application;
use Bitrix24\Lib\Bitrix24Partners\Console\ScrapePartnersCommand;
use Bitrix24\Lib\Bitrix24Partners\Console\ScrapePartnersCommandV2;
use Bitrix24\Lib\Bitrix24Partners\Infrastructure\Scraper\PartnerHtmlParser;
use Bitrix24\Lib\Bitrix24Partners\Infrastructure\Scraper\PartnerPageScraper;
use Symfony\Component\EventDispatcher\Debug\TraceableEventDispatcher;
use Symfony\Component\EventDispatcher\EventDispatcher;
use Symfony\Component\HttpClient\HttpClient;
use Bitrix24\Lib\Bitrix24Partners\Console\ImportPartnersCsvCommand;
use Bitrix24\Lib\Bitrix24Partners\UseCase\Create\Handler;

use Monolog\Logger;
use Monolog\Handler\StreamHandler;
use Symfony\Component\Stopwatch\Stopwatch;

$application = new Application();

$httpClient = HttpClient::create();

$logger = new Logger('bitrix24-lib');
$logger->pushHandler(new StreamHandler(__DIR__ . '/../app.log', Logger::DEBUG));

//$application->addCommand(new ScrapePartnersCommand($httpClient, $logger));
$application->addCommand(new ScrapePartnersCommandV2(
    $logger,
    new PartnerPageScraper($logger),
    new PartnerHtmlParser($logger),
));

$entityManager = EntityManagerFactory::get();
$eventDispatcher = new TraceableEventDispatcher(new EventDispatcher(), new Stopwatch());
$repository = new Bitrix24PartnerRepository($entityManager);
$flusher = new Flusher($entityManager, $eventDispatcher);
$handler = new Handler(
        $repository,
        $flusher,
        PhoneNumberUtil::getInstance(),
        new NullLogger()
);

$application->addCommand(new ImportPartnersCsvCommand($handler));


$application->run();
